{
  "name": "adaptivecash-frontend-take-home",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "workspaces": [
    "apps/Portal.Web",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm --workspace adaptivecash-portal-web run dev",
    "build": "npm --workspace adaptivecash-portal-web run build",
    "test": "npm --workspace adaptivecash-portal-web run test",
    "test:watch": "npm --workspace adaptivecash-portal-web run test:watch",
    "check": "npm run test && npm run build && python scripts/check_architecture.py",
    "dev:prototype": "npm run dev",
    "build:prototype": "npm run build",
    "test:prototype": "npm run test"
  }
}
